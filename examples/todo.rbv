<script type="brief">
let items: List<String> = ["Buy groceries", "Walk the dog", "Read a book"];

txn add_item [true][items.len() == @items.len() + 1] {
  &items = items + ["New task"];
  term;
};

txn clear_all [true][items.len() == 0] {
  &items = [];
  term;
};
</script>

<view>
  <div class="container">
    <h1>Todo App</h1>
    
    <div class="input-row">
      <button id="add-btn" b-trigger:click="add_item">+ Add Task</button>
    </div>
    
    <div id="todo-container">
      <div b-each:item="items" class="todo-item">
        <span b-text="item">Task</span>
      </div>
    </div>
    
    <div class="footer">
      <span><span b-text="items.len()"></span> tasks</span>
      <button id="clear-btn" b-trigger:click="clear_all">Clear All</button>
    </div>
  </div>
</view>

<style>
