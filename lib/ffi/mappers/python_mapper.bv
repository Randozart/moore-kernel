// Python Mapper
//
// Brief FFI mapper for Python via CPython.
// Transforms between Python types and Brief types.
//
// STATUS: Placeholder - requires CPython integration
//
// For documentation, see: spec/MAPPER-GUIDE.md
//
// Python type mappings:
//   str     -> String
//   int     -> Int
//   float   -> Float
//   bytes   -> Data
//   list    -> List<Value>
//   tuple   -> List<Value>
//   dict    -> Struct/Map
//   None    -> Void
//   Exception -> Error

// ============================================================
// Required Functions
// ============================================================

defn map_input(value: Value) -> Value [true][true] {
    term value;
};

defn map_output(value: Value) -> Value [true][true] {
    term value;
};

defn map_error(err: Error) -> Error [true][true] {
    term err;
};

