// ============================================================
// Numeric Conversions
// ============================================================

// Convert Python int to Brief Int
defn py_int_to_brief(py_int: PyInt) -> Int [true][true] {
    term py_int.value;
};

// Convert Brief Int to Python int
defn brief_int_to_py(n: Int) -> PyInt [true][true] {
    term PyInt::from_int(n);
};

// Convert Python float to Brief Float
defn py_float_to_brief(py_float: PyFloat) -> Float [true][true] {
    term py_float.value;
};

// Convert Brief Float to Python float
defn brief_float_to_py(f: Float) -> PyFloat [true][true] {
    term PyFloat::from_float(f);
};

