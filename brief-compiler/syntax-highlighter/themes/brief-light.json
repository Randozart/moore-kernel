{
  "name": "Brief Light",
  "type": "light",
  "colors": {
    "editor.background": "#FFFFFF",
    "editor.foreground": "#000000",
    "editor.lineHighlightBackground": "#F0F0F0",
    "editor.selectionBackground": "#ADD6FF",
    "editorCursor.foreground": "#000000",
    "editorLineNumber.foreground": "#237893"
  },
  "tokenColors": [
    {
      "scope": "keyword.control.txn.brief",
      "settings": { "foreground": "#0000FF", "fontStyle": "bold" }
    },
    {
      "scope": "keyword.control.reactive.brief",
      "settings": { "foreground": "#795E26", "fontStyle": "bold" }
    },
    {
      "scope": "keyword.control.async.brief",
      "settings": { "foreground": "#0000FF", "fontStyle": "italic" }
    },
    {
      "scope": "keyword.control.flow.brief",
      "settings": { "foreground": "#AF00DB", "fontStyle": "bold" }
    },
    {
      "scope": "keyword.declaration.brief",
      "settings": { "foreground": "#0000FF" }
    },
    {
      "scope": "keyword.import.brief",
      "settings": { "foreground": "#0000FF" }
    },
    {
      "scope": "support.type.primitive.brief",
      "settings": { "foreground": "#267F99" }
    },
    {
      "scope": "entity.name.type.custom.brief",
      "settings": { "foreground": "#267F99" }
    },
    {
      "scope": "string.quoted.double.brief",
      "settings": { "foreground": "#A31515" }
    },
    {
      "scope": "constant.numeric.integer.brief",
      "settings": { "foreground": "#098658" }
    },
    {
      "scope": "constant.numeric.float.brief",
      "settings": { "foreground": "#098658" }
    },
    {
      "scope": "constant.language.true.brief",
      "settings": { "foreground": "#0000FF", "fontStyle": "bold" }
    },
    {
      "scope": "constant.language.false.brief",
      "settings": { "foreground": "#0000FF", "fontStyle": "bold" }
    },
    {
      "scope": "comment.line.brief",
      "settings": { "foreground": "#008000", "fontStyle": "italic" }
    },
    {
      "scope": "comment.annotation.brief",
      "settings": { "foreground": "#008000", "fontStyle": "bold" }
    },
    {
      "scope": "meta.annotation.brief",
      "settings": { "foreground": "#795E26", "fontStyle": "bold underline" }
    },
    {
      "scope": "storage.modifier.ownership.brief",
      "settings": { "foreground": "#0000FF", "fontStyle": "bold" }
    },
    {
      "scope": "variable.language.prior-state.brief",
      "settings": { "foreground": "#001080", "fontStyle": "italic" }
    },
    {
      "scope": "keyword.operator.comparison.brief",
      "settings": { "foreground": "#000000" }
    },
    {
      "scope": "keyword.operator.logical.brief",
      "settings": { "foreground": "#000000" }
    },
    {
      "scope": "keyword.operator.term-until.brief",
      "settings": { "foreground": "#795E26", "fontStyle": "bold" }
    },
    {
      "scope": "entity.name.function.brief",
      "settings": { "foreground": "#795E26" }
    },
    {
      "scope": "punctuation.terminator.brief",
      "settings": { "foreground": "#000000" }
    },
    {
      "scope": "punctuation.separator.comma.brief",
      "settings": { "foreground": "#000000" }
    },
    {
      "scope": "meta.attribute.brief-binding",
      "settings": { "foreground": "#D04CA0" }
    },
    {
      "scope": "tag.embedded.script.brief",
      "settings": { "foreground": "#0000FF" }
    },
    {
      "scope": "tag.embedded.view.brief",
      "settings": { "foreground": "#0000FF" }
    },
    {
      "scope": "tag.embedded.style.brief",
      "settings": { "foreground": "#0000FF" }
    },
    {
      "scope": "text.plain",
      "settings": { "foreground": "#000000" }
    }
  ]
}
