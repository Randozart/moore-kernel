// Standard Math Library
//
// Functions marked with 'frgn' require foreign implementation.
// Functions with 'defn' are implemented natively in Brief.

// ===== PURE FOREIGN (requires external implementation) =====

// Trigonometry
frgn __sin(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __cos(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __tan(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __asin(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __acos(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __atan(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __atan2(y: Float, x: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __sinh(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __cosh(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __tanh(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
// Advanced math
frgn __sqrt(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __cbrt(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __pow(base: Float, exp: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __powi(base: Float, exp: Int) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __exp(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __exp2(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __ln(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __log(n: Float, base: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __log2(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __log10(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
// Float-specific rounding
frgn __floor(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __ceil(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __round(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __trunc(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
