// Float checks
frgn __is_nan(n: Float) -> Result<Bool, MathError> from "std/bindings/math.toml";
frgn __is_infinite(n: Float) -> Result<Bool, MathError> from "std/bindings/math.toml";
frgn __is_finite(n: Float) -> Result<Bool, MathError> from "std/bindings/math.toml";
frgn __is_normal(n: Float) -> Result<Bool, MathError> from "std/bindings/math.toml";
// Float operations
frgn __signum_float(n: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __clamp_float(val: Float, min: Float, max: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __min_float(a: Float, b: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
frgn __max_float(a: Float, b: Float) -> Result<Float, MathError> from "std/bindings/math.toml";
// Integer-specific
frgn __div_rem(a: Int, b: Int) -> Result<Int, MathError> from "std/bindings/math.toml";
