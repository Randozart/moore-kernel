# Brief Compiler

# ============================================
# SPECS
# ============================================
# spec/ is NOT ignored - we track specification files
# Only ignore generated spec outputs
spec/*.pdf
spec/*.html

# Old docs drafts (not authoritative)
spec/old_docs/

# ============================================
# TESTS
# ============================================
tests/

# ============================================
# TEST PROJECTS (generated by `brief init`)
# ============================================
test-project/

# ============================================
# RUST BUILD ARTIFACTS
# ============================================
/target/
**/*.rs.bk
Cargo.lock

# ============================================
# FFI NATIVE LIBRARY (generated build artifacts)
# ============================================
lib/ffi/native/target/
lib/ffi/native/Cargo.lock

# ============================================
# GENERATED FILES
# ============================================
*.bc.json
test-*.js
test-*.js.map
test-*.d.ts
test-*.d.ts.map
generated/
landing-build/
page-build/
*_build/

# ============================================
# NODE/JAVASCRIPT (legacy tooling)
# ============================================
node_modules/
package-lock.json
package.json
!syntax-highlighter/package.json
!syntax-highlighter/*.vsix
tsconfig.json
dist/

# ============================================
# IMAGES & LOGOS
# ============================================
*.gif

# ============================================
# EDITOR & IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# ENVIRONMENT & SECRETS
# ============================================
.env
.env.local
*.log
CODICIL_CHECKING.md
