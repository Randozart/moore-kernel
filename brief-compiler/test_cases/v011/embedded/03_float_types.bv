// Test: Float type parsing
// Category: Embedded - Float
// Note: Float not supported in verilog synthesis, but parses correctly

let temperature: Float = 3.14;
let pressure: Float = 1.01325;
let reading: Int = 0;

// Float variables can be declared and used in transactions
// but actual Float operations require fixed-point for synthesis

rct txn read_sensor [reading >= 0]
  [reading >= 0]
{
    &reading = reading + 1;
    term;
};