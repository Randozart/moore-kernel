// Test: Embedded Brief with vector type and bit-range addressing
// Category: Embedded - Vectors
// Expected: Compiles to SystemVerilog with proper bit widths

let buffer: Int[16] @ 0x80001000 /x16;
let control: UInt @ 0x80000000 /0..7 = 0;

rct txn init_buffer [control == 0]
  [control == 1]
{
    &control = 1;
    term;
};

rct txn write_element [control == 1]
  [buffer[0] == 42]
{
    &buffer[0] = 42;
    term;
};